# ─── Neo4j ────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_strong_password_here

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here

# ─── ChromaDB ─────────────────────────────────────────────────
CHROMA_TOKEN=your_chroma_token_here

# ─── Google ADK / Gemini ──────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
GOOGLE_ADC_PATH=C:\Users\trina\AppData\Roaming\gcloud\application_default_credentials.json

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO